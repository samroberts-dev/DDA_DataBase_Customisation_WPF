<Window x:Class="DDA_Week12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DDA_Week12"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="10">
            <Button Content="CREATE" Click="ShowCreationPage" Margin="0,0,25,0"/>
            <Button Content="INSERT" Click="ShowInsertionPage" Margin="0,0,25,0"/>
            <Button Content="SELECT" Click="ShowSelectionPage" Margin="0,0,25,0"/>
        </StackPanel>
        <Grid x:Name="Grid_Select" Margin="0,40,0,0" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <ListBox x:Name="ListBox_Display_Tables" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="1" Grid.RowSpan="4" SelectionChanged="Selection_Changed_Display_Tables"></ListBox>
            <ListBox x:Name="ListBox_Display_Fields" Grid.Column="2" Grid.Row="2" Grid.ColumnSpan="1" Grid.RowSpan="4" SelectionChanged="ListBox_Display_Fields_SelectionChanged"></ListBox>
            <ListBox x:Name="ListBox_Display_Results" Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="2" Grid.RowSpan="4"></ListBox>
            <TextBox x:Name="TextBox_Table_Entry" Grid.Column="1" Grid.Row="1" TextChanged="TextBox_TextChanged"></TextBox>
            <Label Grid.Column="1" Grid.Row="0" Content="TABLE" VerticalAlignment="Bottom" HorizontalAlignment="Center"></Label>
            <Label Grid.Column="2" Grid.Row="0" Content="FIELD" VerticalAlignment="Bottom" HorizontalAlignment="Center"></Label>
            <Label Grid.Column="3" Grid.Row="0" Content="VALUE" VerticalAlignment="Bottom" HorizontalAlignment="Center"></Label>
            <TextBox x:Name="TextBox_Field_Entry" Grid.Column="2" Grid.Row="1"></TextBox>
            <TextBox x:Name="TextBox_Value_Entry" Grid.Column="3" Grid.Row="1"></TextBox>
            <Button Grid.Column="4" Content="SEARCH" Grid.Row="1" Click="Button_Click"></Button>
        </Grid>

        

    </Grid>
</Window>
